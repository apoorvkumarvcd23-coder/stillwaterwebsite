// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       Int                @id @default(autoincrement())
  createdAt                DateTime           @default(now())
  name                     String             @default("")
  email                    String             @default("")
  phone                    String             @default("")
  age                      Int                @default(0)
  gender                   String             @default("")
  height                   Float              @default(0)
  weight                   Float              @default(0)
  occupation_type          String             @default("")
  
  // Step 2: Diet
  diet_breakfast           String             @default("")
  diet_lunch               String             @default("")
  diet_dinner              String             @default("")
  diet_snacks              String             @default("")
  diet_snacks_time         String             @default("")
  
  // Step 3: Lifestyle
  bed_time                 String             @default("")
  wake_up_time             String             @default("")
  water_glasses            Int                @default(0)
  exercise_info            String             @default("")
  
  // Step 4: Eye Health
  eye_condition            String             @default("")
  wears_spectacles         Boolean            @default(false)
  
  // Step 6: Goals
  health_goals             String             @default("")

  conditions               UserCondition[]
  symptoms                 UserSymptom[]
  goals                    UserGoal[]
  recommendations          Recommendation[]
}

model UserGoal {
  id        Int    @id @default(autoincrement())
  userId    Int
  goal_name String
  user      User   @relation(fields: [userId], references: [id])
}

model UserCondition {
  id             Int    @id @default(autoincrement())
  userId         Int
  condition_name String
  user           User   @relation(fields: [userId], references: [id])
}

model UserSymptom {
  id           Int    @id @default(autoincrement())
  userId       Int
  symptom_name String
  user         User   @relation(fields: [userId], references: [id])
}

model Recommendation {
  id                       Int      @id @default(autoincrement())
  userId                   Int
  sharan_score             Int
  eye_yoga_score           Int
  healy_score              Int
  retreat_score            Int
  primary_recommendation   String
  secondary_recommendation String?
  primary_explanation      String?
  secondary_explanation    String?
  createdAt                DateTime @default(now())
  user                     User     @relation(fields: [userId], references: [id])
}

model ServiceRule {
  id        Int    @id @default(autoincrement())
  type      String // "condition", "symptom", "goal", "lifestyle"
  attribute String // e.g., "diabetes", "tired eyes", "lose weight", "processed_food_frequency"
  value     String? // For exact matches on lifestyle, e.g. "daily"
  operator  String? // e.g., ">", "==", for ranges
  service   String // "SHARAN", "EYE_YOGA", "HEALY", "RETREAT"
  score     Int
}
